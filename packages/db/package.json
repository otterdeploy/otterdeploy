{
  "name": "@otterstack/db",
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./*": {
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "db:push": "bun --env-file ../../.env -- drizzle-kit push",
    "db:generate": "bun --env-file ../../.env drizzle-kit generate",
    "db:studio": "bun --env-file ../../.env drizzle-kit studio",
    "db:migrate": "bun --env-file ../../.env drizzle-kit migrate",
    "db:start": "docker compose up -d",
    "db:watch": "docker compose up",
    "db:stop": "docker compose stop"
  },
  "dependencies": {
    "@otterstack/env": "workspace:*",
    "@otterstack/shared": "workspace:*",
    "@upstash/redis": "^1.37.0",
    "drizzle-orm": "^0.45.2",
    "pg": "^8.16.3",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@otterstack/config": "workspace:*",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "catalog:"
  }
}
