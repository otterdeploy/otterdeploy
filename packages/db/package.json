{
  "name": "@otterstack/db",
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./*": {
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "env": "bun --env-file=../../.env",
    "db:push": "bun run env drizzle-kit push",
    "db:generate": "bun run env drizzle-kit generate",
    "db:studio": "bun run env drizzle-kit studio",
    "db:migrate": "bun run env drizzle-kit migrate"
  },
  "dependencies": {
    "@otterstack/env": "workspace:*",
    "drizzle-orm": "^0.45.1",
    "pg": "^8.17.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@otterstack/config": "workspace:*",
    "@types/pg": "^8.16.0",
    "drizzle-kit": "^0.31.8",
    "typescript": "catalog:"
  }
}
