    "@orpc/server": "catalog:",
    "@orpc/zod": "catalog:",
    "@otterdeploy/auth": "workspace:*",
    "@otterdeploy/db": "workspace:*",
    "@otterdeploy/docker": "^0.4.0",
    "@otterdeploy/email": "workspace:*",
    "@otterdeploy/env": "workspace:*",
    "@otterdeploy/jobs": "workspace:*",
    "@otterdeploy/shared": "workspace:*",
    "better-result": "^2.9.2",
    "cron-parser": "^4.9.0",
    "drizzle-orm": "catalog:",
    "drizzle-zod": "catalog:",
    "evlog": "catalog:",
    "hono": "catalog:",
    "yaml": "^2.9.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@otterdeploy/config": "workspace:*",
    "@vitest/coverage-v8": "catalog:",
    "@vitest/ui": "catalog:",
    "jsdom": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
