{
  "name": "@otterdeploy/api",
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./*": {
      "default": "./src/*.ts"
    },
    "./manifest": {
      "default": "./src/stack/manifest/index.ts"
    },
    "./caddy": {
      "default": "./src/caddy/index.ts"
    },
    "./edge-logs": {
      "default": "./src/edge-logs/index.ts"
    },
    "./git": {
      "default": "./src/git/index.ts"
    },
    "./swarm": {
      "default": "./src/swarm/index.ts"
    },
    "./backups": {
      "default": "./src/backups/index.ts"
    },
    "./metrics": {
      "default": "./src/metrics/index.ts"
    }
  },
  "scripts": {
    "test": "bun --bun vitest run"
  },
  "dependencies": {
    "@orpc/client": "catalog:",
    "@orpc/contract": "^1.14.1",
    "@orpc/openapi": "catalog:",
    "@orpc/server": "catalog:",
    "@orpc/zod": "catalog:",
    "@otterdeploy/auth": "workspace:*",
    "@otterdeploy/db": "workspace:*",
    "@otterdeploy/docker": "^0.4.0",
    "@otterdeploy/email": "workspace:*",
    "@otterdeploy/env": "workspace:*",
    "@otterdeploy/jobs": "workspace:*",
    "@otterdeploy/shared": "workspace:*",
    "better-result": "^2.9.2",
    "cron-parser": "^4.9.0",
    "drizzle-orm": "catalog:",
    "drizzle-zod": "catalog:",
    "evlog": "catalog:",
    "hono": "catalog:",
    "yaml": "^2.9.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@otterdeploy/config": "workspace:*",
    "@types/ssh2-sftp-client": "^9.0.6",
    "@vitest/coverage-v8": "catalog:",
    "@vitest/ui": "catalog:",
    "jsdom": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "optionalDependencies": {
    "maxmind": "^4.3.24",
    "ssh2-sftp-client": "^11.0.0"
  },
  "optionalDependenciesNotes": {
    "maxmind": "optional GeoIP reader for edge logs — only loaded when EDGE_LOG_GEOIP_DB is set; code degrades to null country without it (see edge-logs/geo.ts).",
    "ssh2-sftp-client": "loaded lazily only for sftp backup destinations (storage.ts); optional so ssh2's native build can't break install for local/s3-only operators — sftp runs fail with an actionable 'run bun install' message until present."
  }
}
