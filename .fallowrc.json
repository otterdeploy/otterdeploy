{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "entry": ["src/index.{ts,tsx,js,jsx}", "src/main.{ts,tsx,js,jsx}"],
  "ignorePatterns": [
    "apps/web-demo/**",
    "research/**",
    ".agents/**",
    ".claude/**"
  ],
  "workspaces": {
    "packages": ["apps/*", "packages/*"]
  },
  "duplicates": {
    "minOccurrences": 3,
    "ignore": ["apps/web-demo/**"]
  },
  "rules": {},
  "ignoreExports": [
    {
      "file": "apps/web/src/features/projects/components/new-resource/form-primitives.tsx",
      "exports": ["*"]
    },
    {
      "file": "apps/web/src/shared/components/ui/field.tsx",
      "exports": ["*"]
    },
    {
      "file": "apps/web/src/features/projects/components/graph/resource-node.tsx",
      "exports": ["*"]
    },
    {
      "file": "apps/web/src/features/projects/components/graph/resource-to-node.ts",
      "exports": ["*"]
    },
    {
      "file": "apps/web/src/features/projects/components/framework-logo.tsx",
      "exports": ["*"]
    },
    {
      "file": "apps/web/src/features/projects/components/new-resource/frameworks.ts",
      "exports": ["*"]
    },
    {
      "file": "apps/cli/src/config-file.ts",
      "exports": ["*"]
    },
    {
      "file": "apps/cli/src/config.ts",
      "exports": ["*"]
    },
    {
      "file": "packages/api/src/routers/backups/contract.ts",
      "exports": ["*"]
    },
    {
      "file": "packages/api/src/routers/notifications/contract.ts",
      "exports": ["*"]
    }
  ]
}
