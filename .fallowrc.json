{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "entry": ["src/index.{ts,tsx,js,jsx}", "src/main.{ts,tsx,js,jsx}"],
  "ignorePatterns": [
    "apps/web-demo/**",
    "research/**",
    ".agents/**",
    ".claude/**"
  ],
  "workspaces": {
    "packages": ["apps/*", "packages/*"]
  },
  "duplicates": {
    "minOccurrences": 3,
    "ignore": ["apps/web-demo/**"]
  },
  "rules": {}
}
