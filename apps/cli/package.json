{
  "name": "@otterdeploy/cli",
  "version": "0.1.0",
  "description": "Deploy and operate otterdeploy projects from the terminal.",
  "keywords": [
    "caddy",
    "cli",
    "deploy",
    "docker",
    "otterdeploy",
    "paas",
    "self-hosted"
  ],
  "homepage": "https://github.com/otterdeploy/otterdeploy/tree/main/apps/cli#readme",
  "bugs": "https://github.com/otterdeploy/otterdeploy/issues",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/otterdeploy/otterdeploy.git",
    "directory": "apps/cli"
  },
  "bin": {
    "otterdeploy": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun run scripts/build.ts",
    "compile": "bun build --compile --minify --sourcemap ./src/index.ts --outfile otterdeploy",
    "compile:all": "bun run scripts/compile-all.ts",
    "prepack": "bun run scripts/build.ts",
    "start": "bun run src/index.ts",
    "test": "bun --bun vitest run",
    "typecheck": "tsc --noEmit --checkers 4"
  },
  "devDependencies": {
    "@orpc/client": "catalog:",
    "@otterdeploy/api": "workspace:*",
    "@otterdeploy/config": "workspace:*",
    "@otterdeploy/shared": "workspace:*",
    "@types/bun": "catalog:",
    "better-auth": "catalog:",
    "better-result": "catalog:",
    "citty": "^0.1.6",
    "consola": "^3.2.3",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "zod": "catalog:"
  },
  "engines": {
    "node": ">=20"
  },
  "//": "All deps are devDependencies: they're bundled into dist/index.js at build time (bun build), so the published package installs nothing. The workspace packages are needed at build/typecheck/test time and must be declared for CI's frozen install to resolve them."
}
