{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "env": "bun --env-file=../../.env",
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "bun run env --hot src/index.ts",
    "start": "bun run env dist/index.mjs"
  },
  "dependencies": {
    "@orpc/openapi": "^1.13.5",
    "@orpc/server": "^1.13.5",
    "@orpc/zod": "^1.13.5",
    "@otterstack/api": "workspace:*",
    "@otterstack/auth": "workspace:*",
    "@otterstack/db": "workspace:*",
    "@otterstack/env": "workspace:*",
    "better-auth": "^1.4.18",
    "hono": "^4.11.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@otterstack/config": "workspace:*",
    "@types/bun": "^1.3.9",
    "tsdown": "^0.16.8",
    "typescript": "^5.9.3"
  }
}
