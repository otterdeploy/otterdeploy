{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "portless api.otterstack bun run --env-file ../../.env --hot src/index.ts",
    "start": "bun run dist/index.js"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.74.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.216.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.216.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-metrics": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.216.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@orpc/openapi": "catalog:",
    "@orpc/server": "catalog:",
    "@orpc/zod": "catalog:",
    "@otterdeploy/docker": "^0.4.0",
    "@otterstack/api": "workspace:*",
    "@otterstack/auth": "workspace:*",
    "@otterstack/db": "workspace:*",
    "@otterstack/email": "workspace:*",
    "@otterstack/env": "workspace:*",
    "@otterstack/jobs": "workspace:*",
    "ai": "^6.0.175",
    "better-auth": "catalog:",
    "better-result": "catalog:",
    "evlog": "catalog:",
    "hono": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@otterstack/config": "workspace:*",
    "@types/bun": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "@vitest/ui": "catalog:",
    "jsdom": "catalog:",
    "tsdown": "^0.21.10",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
