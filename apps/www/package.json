{
  "name": "www",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "build": "vite build",
    "build:vercel": "NITRO_PRESET=vercel vite build",
    "dev": "portless www.otterdeploy --force vite dev",
