{
  "name": "otterdeploy",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "zod": "^4.4.3",
      "typescript": "^7.0.1-rc",
      "@types/bun": "^1.3.13",
      "@types/react": "^19.2.14",
      "better-result": "^2.9.2",
      "hono": "^4.12.16",
      "@orpc/server": "^1.14.1",
      "@orpc/openapi": "^1.14.1",
      "@orpc/zod": "^1.14.1",
      "better-auth": "^1.6.9",
      "react": "^19.2.5",
      "vitest": "^4.1.5",
      "@vitest/ui": "^4.1.5",
      "@vitest/coverage-v8": "^4.1.5",
      "jsdom": "^29.1.1",
      "@orpc/client": "^1.14.1",
      "evlog": "^2.17.0",
      "drizzle-orm": "^1.0.0-rc.3",
      "drizzle-zod": "^1.0.0-beta.14",
      "@tanstack/db": "^0.6.7",
      "@tanstack/db-ivm": "^0.1.18",
      "@tanstack/query-core": "^5.100.14",
      "@tanstack/query-db-collection": "^1.0.38",
      "@tanstack/react-db": "^0.1.85",
      "@tanstack/react-form": "^1.32.0",
      "@tanstack/react-hotkeys": "^0.10.0",
      "@tanstack/react-query": "^5.100.14",
      "@tanstack/react-query-devtools": "^5.100.14",
      "@tanstack/react-router": "^1.170.7",
      "@tanstack/react-router-devtools": "^1.167.0",
      "@tanstack/react-virtual": "^3.13.25",
      "@tanstack/router-cli": "^1.166.40",
      "@tanstack/router-plugin": "^1.168.10"
    }
  },
  "type": "module",
  "scripts": {
    "build": "turbo build",
    "db:down": "turbo -F @otterdeploy/db db:down",
    "db:generate": "turbo -F @otterdeploy/db db:generate",
    "db:migrate": "turbo -F @otterdeploy/db db:migrate",
    "db:push": "turbo -F @otterdeploy/db db:push",
    "db:start": "turbo -F @otterdeploy/db db:start",
    "db:stop": "turbo -F @otterdeploy/db db:stop",
    "db:studio": "turbo -F @otterdeploy/db db:studio",
    "db:watch": "turbo -F @otterdeploy/db db:watch",
    "dev": "turbo dev --filter=!builder",
    "dev:native": "turbo -F native dev",
    "dev:server": "turbo -F server dev",
    "dev:web": "turbo -F web dev",
    "dev:www": "turbo -F www dev",
    "format": "oxfmt --write",
    "infra": "docker compose up -d  --remove-orphans",
    "lint": "oxlint --type-aware --threads=4 --fix",
    "proxy": "sudo portless proxy start --https --lan -p 443",
    "test": "turbo test --filter=!web-demo",
    "typecheck": "turbo typecheck --concurrency=4 --filter=!web-demo"
  },
  "dependencies": {
    "@otterdeploy/env": "workspace:*",
    "@tanstack/eslint-plugin-query": "^5.101.1",
    "@tanstack/eslint-plugin-router": "^1.162.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "portless": "^0.14.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@otterdeploy/config": "workspace:*",
    "@types/bun": "catalog:",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "oxlint-tsgolint": "^0.23.0",
    "turbo": "^2.9.14",
    "typescript": "catalog:",
    "vite-plus": "0.2.1"
  },
  "overrides": {
    "hono": "^4.12.16"
  },
  "packageManager": "bun@1.3.10"
}
