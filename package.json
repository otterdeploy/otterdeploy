{
  "name": "otterstack",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "zod": "^4.1.13",
      "typescript": "^5",
      "@types/bun": "^1.3.4",
      "hono": "^4.8.2",
      "@orpc/server": "^1.12.2",
      "@orpc/openapi": "^1.12.2",
      "@orpc/zod": "^1.12.2",
      "better-auth": "^1.4.18",
      "@orpc/client": "^1.12.2"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @otterstack/db db:push",
    "db:studio": "turbo -F @otterstack/db db:studio",
    "db:generate": "turbo -F @otterstack/db db:generate",
    "db:migrate": "turbo -F @otterstack/db db:migrate",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "check": "oxlint && oxfmt --write",
    "ruler:apply": "bunx @intellectronica/ruler@latest apply --local-only"
  },
  "dependencies": {
    "@otterstack/env": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@otterstack/config": "workspace:*",
    "@types/bun": "^1.3.9",
    "oxfmt": "^0.26.0",
    "oxlint": "^1.47.0",
    "turbo": "^2.8.9",
    "typescript": "^5.9.3"
  },
  "packageManager": "bun@1.3.7"
}
