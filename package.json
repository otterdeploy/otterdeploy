{
  "name": "otterstack",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@base-ui/react": "^1.2.0",
      "@fontsource-variable/figtree": "^5.2.10",
      "@hugeicons/core-free-icons": "^3.1.1",
      "@hugeicons/react": "^1.1.5",
      "@orpc/contract": "^1.13.5",
      "@orpc/client": "^1.13.5",
      "@orpc/openapi": "^1.13.5",
      "@orpc/server": "^1.13.5",
      "@orpc/zod": "^1.13.5",
      "@types/bun": "^1.3.9",
      "@types/react": "19.2.7",
      "@types/react-dom": "19.2.3",
      "@xyflow/react": "^12.9.0",
      "better-auth": "^1.4.18",
      "better-result": "latest",
      "class-variance-authority": "^0.7.1",
      "clsx": "^2.1.1",
      "cmdk": "^1.1.1",
      "date-fns": "^4.1.0",
      "embla-carousel-react": "^8.6.0",
      "hono": "^4.11.9",
      "inngest": "^3.27.0",
      "input-otp": "^1.4.2",
      "lucide-react": "^0.473.0",
      "next-themes": "^0.4.6",
      "react": "19.2.3",
      "react-day-picker": "^9.13.2",
      "react-dom": "19.2.3",
      "react-resizable-panels": "^4.6.4",
      "recharts": "2.15.4",
      "shadcn": "^3.8.4",
      "sonner": "^2.0.7",
      "tailwind-merge": "^3.4.1",
      "tailwindcss": "^4.1.18",
      "tw-animate-css": "^1.4.0",
      "pino": "^9.6.0",
      "pino-pretty": "^13.0.0",
      "typescript": "^5.9.3",
      "vaul": "^1.1.2",
      "zod": "^4.3.6"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "contract:check": "turbo contract:check",
    "contract:update": "turbo contract:update",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "dev:worker": "turbo -F @otterstack/worker dev",
    "db:push": "turbo -F @otterstack/db db:push",
    "db:studio": "turbo -F @otterstack/db db:studio",
    "db:generate": "turbo -F @otterstack/db db:generate",
    "db:migrate": "turbo -F @otterstack/db db:migrate",
    "db:seed": "turbo -F @otterstack/db db:seed --",
    "infra:up": "docker compose up -d",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "infra:sync": "turbo -F @otterstack/cli dev -- sync",
    "infra:preview": "turbo -F @otterstack/cli dev -- preview",
    "infra:init": "turbo -F @otterstack/cli dev -- init",
    "infra:status": "turbo -F @otterstack/cli dev -- status",
    "infra:destroy": "turbo -F @otterstack/cli dev -- destroy",
    "check": "oxlint && bun run check:result-discipline && oxfmt --write",
    "ruler:apply": "bunx @intellectronica/ruler@latest apply --local-only",
    "check:result-discipline": "bash ./scripts/check-result-discipline.sh"
  },
  "dependencies": {
    "@otterstack/env": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@otterstack/config": "workspace:*",
    "@types/bun": "^1.3.9",
    "oxfmt": "^0.32.0",
    "oxlint": "^1.47.0",
    "turbo": "^2.8.9",
    "typescript": "^5.9.3"
  },
  "packageManager": "bun@1.3.7"
}
