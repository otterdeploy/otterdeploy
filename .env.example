NODE_ENV=development
VITE_SERVER_URL=http://api.otterstack.localhost:1355

# Authentication
BETTER_AUTH_SECRET=replace-with-at-least-32-char-secret
BETTER_AUTH_URL=http://api.otterstack.localhost:1355
CORS_ORIGIN=http://otterstack.localhost:1355

# Infisical (managed gateway mode)
INFISICAL_GATEWAY_URL=http://localhost:8080
INFISICAL_GATEWAY_TOKEN=
INFISICAL_MACHINE_IDENTITY_CLIENT_ID=
INFISICAL_MACHINE_IDENTITY_CLIENT_SECRET=
INFISICAL_PROJECT_PREFIX=otterstack

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=postgres
POSTGRES_PORT=5432  

DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PORT}/${POSTGRES_DB}

# Inngest
INNGEST_EVENT_KEY=local-dev-event-key
INNGEST_SIGNING_KEY=local-dev-signing-key
INNGEST_DEV=1
INNGEST_BASE_URL=http://localhost:8288

# Zero
ZERO_PORT=4848
ZERO_ADMIN_PASSWORD=zero-admin-dev
ZERO_QUERY_URL=http://api.otterstack.localhost:1355/api/zero/query
ZERO_MUTATE_URL=http://api.otterstack.localhost:1355/api/zero/mutate
VITE_ZERO_URL=http://localhost:4848
